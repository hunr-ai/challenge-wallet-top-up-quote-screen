{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["jest", "react", "react-native"]
  },
  "include": ["src", "tests", "_hunr_hidden", "_hunr_visible"],
  "exclude": ["node_modules"]
}
