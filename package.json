{
  "name": "rn-jest-junior",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.76.6"
  },
  "devDependencies": {
    "@babel/core": "7.26.0",
    "@react-native/babel-preset": "0.76.6",
    "@testing-library/react-native": "12.9.0",
    "@types/jest": "29.5.14",
    "@types/react": "18.3.12",
    "@types/react-test-renderer": "18.3.0",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "5.7.3"
  },
  "jest": {
    "preset": "react-native",
    "testEnvironment": "<rootDir>/hunr-jest-env.cjs",
    "setupFilesAfterEnv": ["@testing-library/react-native/extend-expect"],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "testMatch": [
      "**/tests/**/*.test.(ts|tsx)",
      "**/_hunr_hidden/**/*.test.(ts|tsx)",
      "**/_hunr_visible/**/*.test.(ts|tsx)"
    ]
  },
  "jest-junit": {
    "outputDirectory": ".",
    "outputName": "report.xml"
  }
}
